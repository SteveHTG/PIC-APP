# Supabase config.
# Copy this file to ".env" and fill in the values from your Supabase project
# (Project Settings > API > Project URL and Project API keys > "anon public").
#
# NOTE: The anon key is bundled into the client and is NOT secret — that is
# normal for Supabase. Data is protected by Row Level Security (RLS) policies,
# not by hiding this key. (Never put the service_role key in a VITE_ var.)
#
# The app runs on mock data until these are filled in.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: simple gate for the /admin screen (placeholder auth for now).
VITE_ADMIN_PASSCODE=changeme
